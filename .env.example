# Token para validar webhooks recebidos (escolha qualquer string secreta)
WEBHOOK_SECRET=meu_token_secreto_aqui

# Meta for Developers — crie em https://developers.facebook.com
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# URL base do servidor (usada no OAuth callback do Meta)
BASE_URL=http://localhost:3000

# Porta do servidor
PORT=3000
